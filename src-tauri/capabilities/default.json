{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Field Check",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/scanner",
          "sidecar": true
        }
      ]
    },
    {
      "identifier": "shell:allow-stdin-write",
      "allow": [
        {
          "name": "binaries/scanner",
          "sidecar": true
        }
      ]
    },
    "shell:allow-kill",
    "dialog:allow-open",
    "dialog:allow-save",
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "**" }]
    }
  ]
}
