{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Field Check",
  "version": "0.1.0",
  "identifier": "co.usefield.field-check",
  "build": {
    "frontendDist": "../gui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd gui && npm run dev",
    "beforeBuildCommand": "cd gui && npm run build"
  },
  "app": {
    "title": "Field Check",
    "windows": [
      {
        "title": "Field Check",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/scanner"
    ]
  }
}
